# Copia in authelia/.env e compila con i dati reali del tuo provider SMTP.
# .env resta fuori da git (vedi .gitignore), solo questo .example è tracciato.
# Vedi notifier in configuration.yml e i commenti in docker-compose.yml.

# Schema URL: submission:// (STARTTLS, porta 587) o smtps:// (TLS implicito, porta 465)
AUTHELIA_NOTIFIER_SMTP_ADDRESS=submission://smtp.tuoprovider.it:587
AUTHELIA_NOTIFIER_SMTP_SENDER=Authelia <noreply@tuodominio.it>
# HELO/EHLO: uno dei domini serviti, es. auth.whalestudio.dev
AUTHELIA_NOTIFIER_SMTP_IDENTIFIER=auth.whalestudio.dev
AUTHELIA_NOTIFIER_SMTP_USERNAME=utente_smtp
AUTHELIA_NOTIFIER_SMTP_PASSWORD=
