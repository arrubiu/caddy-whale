# API key per il bouncer HTTP di Caddy
# Genera con: docker exec crowdsec cscli bouncers add caddy-bouncer
CROWDSEC_BOUNCER_API_KEY=

# Segreti Authelia: NON qui — Authelia stessa raccomanda i secret su file,
# non variabili d'ambiente in chiaro (leggibili con `docker inspect`/`ps`).
# Crea questi file prima di avviare (cartella ignorata da git, vedi .gitignore):
#   mkdir -p authelia/secrets
#   openssl rand -hex 32 > authelia/secrets/jwt_secret
#   openssl rand -hex 32 > authelia/secrets/session_secret
#   openssl rand -hex 32 > authelia/secrets/storage_encryption_key
#
# Quando in futuro attivi identity_providers.oidc (Drupal/Grafana/Portainer,
# vedi authelia/oidc.yml.example):
#   openssl rand -hex 32 > authelia/secrets/oidc_hmac_secret
#   openssl genrsa -out authelia/secrets/oidc_issuer_private_key.pem 4096
#   docker run --rm authelia/authelia:4.39.20 authelia crypto hash generate \
#     pbkdf2 --variant sha512 --password 'IL_SECRET_IN_CHIARO_DEL_CLIENT'
#   (l'hash generato va in authelia/oidc.yml; il valore IN CHIARO è quello
#   che configuri lato Drupal/Grafana/Portainer)
